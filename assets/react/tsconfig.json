{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "jsx": "react-jsx",

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",

    "paths": {
      "i18next": ["../vendor/i18next/i18next.index.js"],
      "react-i18next": ["../vendor/react-i18next/react-i18next.index.js"],
    }
  }
}

{% extends '@admin/dashboard.html.twig' %}

{% block title %}Panel administratora - Tory | {{ parent() }}{% endblock %}

{% block admin_content %}
    <h3 class="text-center mt-4 mb-4">Zarządzanie torami</h3>
    <a href="{{ path('admin_track_new') }}">
        <button class="btn btn-success mb-3">
            <i class="fa-solid fa-plus"></i>
            Dodaj tor
        </button>
    </a>
    <div class="card bg-dark mb-5">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Nazwa</th>
                            <th>Zdjęcie</th>
                            <th>Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for track in tracks %}
                            <tr>
                                <td>{{ track.id }}</td>
                                <td>{{ track.name }}</td>
                                <td>{{ track.picture }}</td>
                                <td>
                                    <a class="btn btn-outline-success mb-1 mb-md-0" href="{{ path('admin_track_show', {id: track.id}) }}">Wyświetl</a>
                                    <a class="btn btn-outline-info mb-1 mb-md-0" href="{{ path('admin_track_edit', {id: track.id}) }}">Edycja</a>
                                    <form method="post" class="display-inline" action="" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ track.id) }}">
                                        <button class="btn btn-outline-danger mb-1 mb-md-0">Usuń</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5">Nie znaleziono żadnych torów</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
